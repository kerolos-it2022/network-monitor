PORT=4000
SESSION_SECRET=change-this-to-a-random-long-string
DB_PATH=../database/monitoring.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp (اختياري - عبر مزود مثل Twilio أو WhatsApp Cloud API)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TO_NUMBER=

# إشعارات الموبايل (PWA + Web Push عبر VAPID)
# مفاتيح VAPID تُولَّد تلقائياً عند تشغيل deploy.sh install
# أو يدوياً: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
MOBILE_ENABLED=1

# ─────────────────────────────────────────────────────────────
# إعدادات التحديثات من GitHub (GitHub Updates)
# ─────────────────────────────────────────────────────────────
# رابط المستودع — يُقرأ فعلياً من الكود لدعم الـ forks والمستودعات الخاصة.
# مثال: https://github.com/kerolos-it2022/network-monitor.git
GITHUB_REPO_URL=https://github.com/kerolos-it2022/network-monitor.git

# الفرع الافتراضي للتحديثات (يُستخدم كـ fallback عند تعذّر اكتشاف الفرع تلقائياً)
GITHUB_BRANCH=main

# GitHub Personal Access Token (اختياري):
#   - مطلوب للمستودعات الخاصة (بدونه سيفشل طلب releases API).
#   - اختياري للمستودعات العامة، لكنه يرفع حد API من 60 إلى 5000 طلب/ساعة.
# إنشاء من: https://github.com/settings/tokens  (صلاحية: repo للخاص، public_repo للعام)
GITHUB_TOKEN=

# حساب المدير الافتراضي (يُستخدم فقط في أول تشغيل لإنشاء المستخدم)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
