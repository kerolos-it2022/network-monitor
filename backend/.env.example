PORT=4000
SESSION_SECRET=change-this-to-a-random-long-string
DB_PATH=../database/monitoring.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp (اختياري - عبر مزود مثل Twilio أو WhatsApp Cloud API)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TO_NUMBER=

# إشعارات الموبايل (PWA + Web Push عبر VAPID)
# مفاتيح VAPID تُولَّد تلقائياً عند تشغيل deploy.sh install
# أو يدوياً: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
MOBILE_ENABLED=1

# حساب المدير الافتراضي (يُستخدم فقط في أول تشغيل لإنشاء المستخدم)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
