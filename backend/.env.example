PORT=4000
SESSION_SECRET=change-this-to-a-random-long-string
DB_PATH=../database/monitoring.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp (اختياري - عبر مزود مثل Twilio أو WhatsApp Cloud API)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
